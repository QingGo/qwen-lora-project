# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/
docs/
models/
.env
runs/

# ====== Outputs: keep logs/evals/reports, ignore large weights/checkpoints ======
outputs/*/
!outputs/*/training_logs/
!outputs/*/evals/
!outputs/*/reports/
outputs/*/adapters/**/*.safetensors
outputs/*/adapters/**/training_args.bin
outputs/*/adapters/**/tokenizer.json
outputs/*/adapters/**/tokenizer_config.json
outputs/*/adapters/checkpoint-*/

# Training data: ignore large train files, keep val
data/*/train.jsonl
data/*/train_window.jsonl

# Legacy outputs (pre-migration)
outputs_l2/
outputs_l3/
outputs_l4/
outputs_l5/

# Legacy data (pre-migration)
data_l2/
data_l3/
data_test/

# Scripts
run_l4.sh
